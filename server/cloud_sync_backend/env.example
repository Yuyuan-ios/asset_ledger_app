# Server bind. Put nginx/HTTPS in front of this service.
FLEET_SYNC_HOST=127.0.0.1
FLEET_SYNC_PORT=8009

# Request and pull limits.
FLEET_SYNC_MAX_REQUEST_BYTES=4194304
FLEET_SYNC_DEFAULT_PULL_LIMIT=100
FLEET_SYNC_MAX_PULL_LIMIT=500

# SQLite storage. Keep this on persistent ECS disk and back it up.
FLEET_SYNC_DB_PATH=/var/lib/fleet-ledger-cloud-sync/sync.sqlite3

# Authentication. This service intentionally reuses the same token-validation
# configuration as cloud backup so the App can send the existing phone-login
# bearer token. Production should either use the same HS256 JWT secret as the
# account service, or configure token introspection when login tokens are opaque.
FLEET_BACKUP_AUTH_HS256_SECRET=replace-with-long-random-secret
# FLEET_BACKUP_AUTH_JWT_ISSUER=replace-with-issuer
# FLEET_BACKUP_AUTH_JWT_AUDIENCE=fleet-ledger
# FLEET_BACKUP_AUTH_INTROSPECTION_URL=https://api.example.com/v1/auth/introspect
# FLEET_BACKUP_AUTH_INTROSPECTION_BEARER_TOKEN=replace-with-server-to-server-token

# Temporary smoke-test only. Do not enable dev tokens in production.
# FLEET_BACKUP_DEV_TOKENS_JSON={"local-sync-token-a":"test-account-a","local-sync-token-b":"test-account-b"}
