server {
    listen 80;
    server_name backup-api.example.com;

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name backup-api.example.com;

    ssl_certificate     /etc/nginx/certs/backup-api.example.com.pem;
    ssl_certificate_key /etc/nginx/certs/backup-api.example.com.key;

    client_max_body_size 70m;
    client_body_timeout 180s;

    access_log /var/log/nginx/fleet-ledger-cloud-backup.access.log;
    error_log  /var/log/nginx/fleet-ledger-cloud-backup.error.log;

    location = /healthz {
        proxy_pass http://127.0.0.1:8008;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_connect_timeout 30s;
        proxy_send_timeout 180s;
        proxy_read_timeout 180s;
    }

    location /v1/backups {
        proxy_pass http://127.0.0.1:8008;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_connect_timeout 30s;
        proxy_send_timeout 180s;
        proxy_read_timeout 180s;
    }
}
