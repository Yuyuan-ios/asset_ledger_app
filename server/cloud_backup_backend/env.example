# Server bind. Put nginx/HTTPS in front of this service.
FLEET_BACKUP_HOST=127.0.0.1
FLEET_BACKUP_PORT=8008

# Request limits. Nginx should allow at least 70m so the app can enforce this.
FLEET_BACKUP_MAX_PAYLOAD_BYTES=67108864
FLEET_BACKUP_MAX_REQUEST_BYTES=83886080

# Metadata table.
FLEET_BACKUP_DB_PATH=/var/lib/fleet-ledger-cloud-backup/backups.sqlite3

# Optional app-version gate. Unset or unreadable policy path fail-opens and does not block requests.
# FLEET_BACKUP_VERSION_POLICY_PATH=/opt/fleet-ledger-version-policy/version-policy.json

# USER_AUTH_TOKEN plane. Production should either use the same HS256 JWT secret
# as the account service that issues app login tokens, or configure token
# introspection when login tokens are opaque. This plane resolves a stable
# account user_id; it is not an internal service token.
USER_AUTH_HS256_SECRET=replace-with-long-random-secret
# USER_AUTH_JWT_ISSUER=replace-with-issuer
# USER_AUTH_JWT_AUDIENCE=fleet-ledger
# USER_AUTH_INTROSPECTION_URL=https://api.example.com/v1/auth/introspect
# USER_AUTH_INTROSPECTION_SERVICE_TOKEN=replace-with-account-service-token
# USER_AUTH_IDENTITY_CACHE_TTL_SECONDS=900

# Account-bound client-side encryption master key (GET /v1/account/backup-key).
# REQUIRED for encrypted cloud backup: the App derives its AES key from the
# per-account secret = HMAC-SHA256(this master key, user_id). Must be a long,
# high-entropy random string (>= 32 chars). Keep it secret and STABLE: rotating
# it makes existing encrypted backups unrecoverable. Store it apart from the OSS
# bucket so an OSS leak alone cannot decrypt backups.
FLEET_BACKUP_ACCOUNT_KEY_SECRET=replace-with-long-random-master-key-min-32-chars

# Server-side Max entitlement verification. Production must configure an HTTPS
# account/subscription entitlement endpoint; without this, the service fails
# fast at startup. APP_ENV unset is treated as production for this check.
APP_ENV=production
CLOUD_BACKUP_ENTITLEMENT_URL=https://api.example.com/internal/v1/entitlements/verify
SERVICE_INTERNAL_TOKEN=replace-with-cloud-backup-to-iap-token
CLOUD_BACKUP_ENTITLEMENT_TIMEOUT_SECONDS=5
CLOUD_BACKUP_ENTITLEMENT_CACHE_TTL_SECONDS=60

# EXTERNAL_CLIENT_TOKEN plane is Flutter/App only. Do not configure it here and
# do not accept it as server authority.
# EXTERNAL_CLIENT_TOKEN_REQUIRED is false in server config.

# Deprecated env names: migration blocker. Leave unset. If any are configured,
# startup raises ConfigMigrationError; migrate to the new keys above.
# FLEET_BACKUP_AUTH_HS256_SECRET -> USER_AUTH_HS256_SECRET
# FLEET_BACKUP_AUTH_JWT_ISSUER -> USER_AUTH_JWT_ISSUER
# FLEET_BACKUP_AUTH_JWT_AUDIENCE -> USER_AUTH_JWT_AUDIENCE
# FLEET_BACKUP_AUTH_INTROSPECTION_URL -> USER_AUTH_INTROSPECTION_URL
# FLEET_BACKUP_AUTH_INTROSPECTION_BEARER_TOKEN -> USER_AUTH_INTROSPECTION_SERVICE_TOKEN
# FLEET_BACKUP_ENTITLEMENT_VERIFICATION_URL -> CLOUD_BACKUP_ENTITLEMENT_URL
# CLOUD_BACKUP_ENTITLEMENT_TOKEN -> SERVICE_INTERNAL_TOKEN
# FLEET_BACKUP_ENTITLEMENT_BEARER_TOKEN -> SERVICE_INTERNAL_TOKEN
# FLEET_BACKUP_ENTITLEMENT_TIMEOUT_SECONDS -> CLOUD_BACKUP_ENTITLEMENT_TIMEOUT_SECONDS
# FLEET_BACKUP_MAX_ENTITLED_USERS_JSON -> CLOUD_BACKUP_MAX_ENTITLED_USERS_JSON

# Temporary smoke-test/local only:
# FLEET_BACKUP_DEV_TOKENS_JSON={"local-test-token":"test-user"}
# APP_ENV=local
# CLOUD_BACKUP_MAX_ENTITLED_USERS_JSON=["test-user"]

# Object storage. Production uses Aliyun OSS private bucket.
FLEET_BACKUP_STORAGE=oss
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=replace-with-private-bucket
ALIBABA_CLOUD_ACCESS_KEY_ID=replace-with-ram-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=replace-with-ram-access-key-secret
ALIYUN_OSS_PREFIX=fleet-ledger/backups

# Local smoke-test storage, not production:
# FLEET_BACKUP_STORAGE=file
# FLEET_BACKUP_FILE_STORAGE_DIR=/var/lib/fleet-ledger-cloud-backup/objects
