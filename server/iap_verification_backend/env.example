# Server bind. Put nginx/HTTPS in front of this service.
FLEET_IAP_HOST=127.0.0.1
FLEET_IAP_PORT=8010

# SQLite database.
FLEET_IAP_DB_PATH=/var/lib/fleet-ledger-iap/iap_verification.sqlite3

# Request limits.
FLEET_IAP_MAX_REQUEST_BYTES=1048576
FLEET_IAP_APPLE_REQUEST_TIMEOUT_SECONDS=10

# App Store verification contract.
FLEET_IAP_ALLOWED_BUNDLE_ID=com.yuyuan.asset-ledger
FLEET_IAP_ALLOWED_PRODUCTS=com.yuyuan.assetledger.pro.yearly,com.yuyuan.assetledger.max.yearly
FLEET_IAP_APPLE_KEY_ID=replace-with-apple-key-id
FLEET_IAP_APPLE_ISSUER_ID=replace-with-apple-issuer-id
FLEET_IAP_APPLE_PRIVATE_KEY_PATH=/etc/fleet-ledger/AuthKey_REPLACE.p8
FLEET_IAP_APPLE_BUNDLE_ID=com.yuyuan.asset-ledger
FLEET_IAP_APPLE_ROOT_CERTIFICATE_PATHS=/etc/fleet-ledger/AppleRootCA-G3.cer
FLEET_IAP_APPLE_APP_APPLE_ID=1234567890

# Optional USER_AUTH_TOKEN plane for account binding. Configure either the
# account-service HS256 JWT secret or HTTPS token introspection. This resolves
# stable account user_id and must not be reused as the service token.
# USER_AUTH_HS256_SECRET=replace-with-long-random-secret
# USER_AUTH_JWT_ISSUER=replace-with-issuer
# USER_AUTH_JWT_AUDIENCE=fleet-ledger
# USER_AUTH_INTROSPECTION_URL=https://api.example.com/v1/auth/introspect
# USER_AUTH_INTROSPECTION_SERVICE_TOKEN=replace-with-account-service-token
# USER_AUTH_TIMEOUT_SECONDS=5
# USER_AUTH_IDENTITY_CACHE_TTL_SECONDS=900

# SERVICE_INTERNAL_TOKEN plane accepted by POST /internal/v1/entitlements/verify.
# Required before cloud backup can ask IAP for account-level Max entitlement.
SERVICE_INTERNAL_TOKEN=replace-with-long-random-internal-token

# EXTERNAL_CLIENT_TOKEN plane is Flutter/App only. Do not configure it here and
# do not accept it as server authority.
# EXTERNAL_CLIENT_TOKEN_REQUIRED is false in server config.

# Deprecated env names: migration blocker. Leave unset. If any are configured,
# startup raises ConfigMigrationError; migrate to the new keys above.
# FLEET_IAP_AUTH_HS256_SECRET -> USER_AUTH_HS256_SECRET
# FLEET_IAP_AUTH_JWT_ISSUER -> USER_AUTH_JWT_ISSUER
# FLEET_IAP_AUTH_JWT_AUDIENCE -> USER_AUTH_JWT_AUDIENCE
# FLEET_IAP_AUTH_INTROSPECTION_URL -> USER_AUTH_INTROSPECTION_URL
# FLEET_IAP_AUTH_INTROSPECTION_TOKEN -> USER_AUTH_INTROSPECTION_SERVICE_TOKEN
# FLEET_IAP_AUTH_TIMEOUT_SECONDS -> USER_AUTH_TIMEOUT_SECONDS
# IAP_INTERNAL_ENTITLEMENT_TOKEN -> SERVICE_INTERNAL_TOKEN

# Local tests only. Do not enable in production.
# FLEET_IAP_DEV_TOKENS_JSON={"local-login-token":"test-user"}
