# FleetLedger version-policy static delivery.
#
# Include this location in the existing HTTPS server block that already serves
# sync/backup under the same host. The public URL stays on the main API domain:
#   https://<host>/app/version-policy.json
#
# This is static nginx delivery only. Do not proxy this path to sync/backup,
# do not attach application middleware here, and do not apply any future 426
# version gate to version-policy.json itself. The policy must remain reachable
# even when sync/backup application logic is unhealthy.

location = /app/version-policy.json {
    alias /opt/fleet-ledger-version-policy/version-policy.json;
    default_type application/json;

    # Short edge/client cache; clients still keep their own 6-12h app cache.
    add_header Cache-Control "max-age=300, must-revalidate" always;
    add_header X-Content-Type-Options "nosniff" always;
}

