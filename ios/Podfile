# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

def patch_runner_cocoapods_build_settings
  runner_project = Xcodeproj::Project.open(File.join(__dir__, 'Runner.xcodeproj'))
  %w[Runner RunnerTests].each do |target_name|
    target = runner_project.targets.find { |candidate| candidate.name == target_name }
    next unless target

    target.build_configurations.each do |config|
      paths = Array(config.build_settings['FRAMEWORK_SEARCH_PATHS'] || ['$(inherited)'])
      paths << '$(inherited)' unless paths.include?('$(inherited)')
      paths << '$(PODS_CONFIGURATION_BUILD_DIR)' unless paths.include?('$(PODS_CONFIGURATION_BUILD_DIR)')
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] = paths
    end

    next unless target_name == 'Runner'

    target.shell_script_build_phases.each do |phase|
      next unless phase.name == '[CP] Embed Pods Frameworks'

      phase.shell_script = "BUILT_PRODUCTS_DIR=\"${PODS_CONFIGURATION_BUILD_DIR}\" \"${PODS_ROOT}/Target Support Files/Pods-Runner/Pods-Runner-frameworks.sh\"\n"
    end
  end
  runner_project.save
end

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    next unless target.respond_to?(:source_build_phase)

    target.source_build_phase.files.each do |build_file|
      file_ref = build_file.file_ref
      next unless file_ref&.path&.end_with?('.xcprivacy')

      target.source_build_phase.remove_build_file(build_file)
    end
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end

post_integrate do |_installer|
  patch_runner_cocoapods_build_settings
end
